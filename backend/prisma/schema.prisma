generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      String   @default("CUSTOMER")
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id           String   @id @default(cuid())
  customer     User     @relation(fields: [customerId], references: [id])
  customerId   String
  service      Service  @relation(fields: [serviceId], references: [id])
  serviceId    String
  status       String   @default("PENDING")
  quantity     Float
  totalAmount  Float
  pickupDate   DateTime?
  deliveryDate DateTime?
  address      String
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Service {
  id           String   @id @default(cuid())
  name         String
  description  String
  pricePerUnit Float
  unit         String
  imageUrl     String?
  isActive     Boolean  @default(true)
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model Content {
  key   String @id
  value String
  type  String @default("text")
}

model SiteSettings {
  key   String @id
  value String
}
